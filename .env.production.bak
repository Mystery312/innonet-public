# Innonet Production Environment Configuration
# Used by: docker-compose.prod.yml
# NEVER commit this file to version control after filling in real values

# ============================================
# Database Credentials (Docker Compose internal)
# ============================================
POSTGRES_USER=innonet
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=innonet

REDIS_PASSWORD=CHANGE_ME_redis_password

NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ============================================
# Backend Configuration
# ============================================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Database URLs (match the Docker service names and credentials above)
DATABASE_URL=postgresql+asyncpg://innonet:CHANGE_ME_postgres_password@postgres:5432/innonet
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# Environment
ENVIRONMENT=production
DEBUG=false

# CORS - set to your domain or the EC2 public IP
FRONTEND_URL=http://localhost

# API Settings
API_V1_PREFIX=/api/v1
APP_NAME=Innonet API

# ============================================
# External Services (fill in before deploying)
# ============================================
# OpenAI
OPENAI_API_KEY=CHANGE_ME_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4-turbo-preview

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# JWT Settings
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ============================================
# Database Pool Settings
# ============================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_PRE_PING=true

# ============================================
# Monitoring (optional)
# ============================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=20/minute

# ============================================
# Frontend Build Args
# ============================================
VITE_API_URL=/api/v1
