{
  "name": "feature-parity-tester",
  "displayName": "Feature Parity Testing Agent",
  "description": "Automated testing agent for verifying feature parity between local development and production Innonet environments. Tests 49+ test cases across 8 feature areas with comprehensive reporting.",
  "version": "1.0.0",
  "category": "testing",
  "tags": ["testing", "qa", "environment-verification", "ci-cd"],
  "entrypoint": "feature_parity_tester_agent.py",
  "enabled": true,
  "capabilities": {
    "testing": true,
    "reporting": true,
    "analysis": true,
    "automation": true
  },
  "commands": {
    "test": {
      "description": "Run feature parity tests against specified environment(s)",
      "usage": "/agents feature-parity-tester",
      "options": [
        {
          "flag": "--env",
          "values": ["local", "production", "both"],
          "default": "both",
          "description": "Environment to test"
        },
        {
          "flag": "--suite",
          "repeatable": true,
          "description": "Specific test suite(s) to run (auth, profile, events, network, graph, communities, messaging, companies)"
        },
        {
          "flag": "--html",
          "type": "boolean",
          "description": "Generate HTML report"
        },
        {
          "flag": "--verbose",
          "type": "boolean",
          "description": "Verbose output"
        },
        {
          "flag": "--output-dir",
          "default": "test_results",
          "description": "Output directory for reports"
        }
      ]
    },
    "analyze": {
      "description": "Analyze latest test report",
      "usage": "/agents feature-parity-tester --analyze-report",
      "options": [
        {
          "flag": "--analyze-report",
          "type": "boolean",
          "description": "Analyze the latest test report"
        }
      ]
    }
  },
  "outputs": {
    "reports": {
      "json": "test_results/parity_report.json",
      "html": "test_results/parity_report.html"
    },
    "console": "Real-time colored output with statistics"
  },
  "testCoverage": {
    "totalTests": 49,
    "suites": 8,
    "features": {
      "authentication": 6,
      "profiles": 9,
      "events": 4,
      "network": 5,
      "graph": 8,
      "communities": 4,
      "messaging": 3,
      "companies": 3
    }
  },
  "environments": {
    "local": {
      "url": "http://localhost:8000",
      "mode": "read-write",
      "autoCreateUsers": true,
      "rateLimit": "none"
    },
    "production": {
      "url": "https://innonet.work",
      "mode": "read-only",
      "autoCreateUsers": false,
      "rateLimit": "0.5s"
    }
  },
  "performance": {
    "executionTime": "~2 seconds",
    "memoryUsage": "~50MB",
    "apiCallsPerRun": "~37",
    "parallelization": "async"
  },
  "requirements": {
    "python": "3.11+",
    "packages": [
      "httpx>=0.28.1",
      "pydantic>=2.0"
    ],
    "backends": ["FastAPI", "PostgreSQL", "Neo4j"]
  },
  "documentation": {
    "overview": "FEATURE_PARITY_TESTING.md",
    "completion": "PHASE3_COMPLETION_REPORT.md",
    "sourceCode": "backend/tests/",
    "entryPoint": "feature_parity_test.py"
  },
  "examples": [
    {
      "description": "Test both environments",
      "command": "/agents feature-parity-tester"
    },
    {
      "description": "Test local environment only",
      "command": "/agents feature-parity-tester --env local"
    },
    {
      "description": "Test production environment",
      "command": "/agents feature-parity-tester --env production"
    },
    {
      "description": "Test specific features",
      "command": "/agents feature-parity-tester --suite auth --suite graph"
    },
    {
      "description": "Generate HTML report with verbose output",
      "command": "/agents feature-parity-tester --html --verbose"
    },
    {
      "description": "Analyze latest test report",
      "command": "/agents feature-parity-tester --analyze-report"
    }
  ],
  "integrations": {
    "cicd": "GitHub Actions, GitLab CI, Jenkins",
    "notifications": "Slack, Email",
    "scheduling": "Cron, AWS EventBridge",
    "storage": "S3, GCS, Local filesystem"
  },
  "helpTopics": {
    "troubleshooting": "See PHASE3_COMPLETION_REPORT.md Troubleshooting section",
    "faq": "See FEATURE_PARITY_TESTING.md FAQ",
    "configuration": "See backend/tests/config.py"
  },
  "metadata": {
    "author": "Innonet Engineering Team",
    "createdDate": "2026-03-07",
    "lastUpdated": "2026-03-07",
    "status": "production",
    "reliability": "production-grade",
    "supportLevel": "full"
  }
}
