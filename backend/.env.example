# Development Environment Configuration Template
# Copy this file to .env and replace with actual values
# NEVER commit .env file to git!

# Security - Generate using: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-secret-key-here-min-512-bits

# Data Encryption - Generate using: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used for encrypting sensitive fields at rest (phone numbers, PII)
ENCRYPTION_KEY=your-fernet-key-here

# Database Configuration - Choose ONE of these approaches:
#
# OPTION 1: Connection Strings (simple, traditional)
DATABASE_URL=postgresql+asyncpg://postgres:your-password-here@postgres:5432/innonet
REDIS_URL=redis://:your-password-here@redis:6379/0
#
# OPTION 2: Individual Variables (recommended for production/secret managers)
# If you prefer individual variables, comment out DATABASE_URL and REDIS_URL above
# and uncomment these:
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=innonet
# DB_USER=postgres
# DB_PASSWORD=your-password-here
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=your-password-here

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_PASSWORD=your-neo4j-password-here

# Application Settings
DEBUG=true
FRONTEND_URL=http://localhost:5173

# Optional API Keys (leave empty if not using)
OPENAI_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@innonet.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional - For encryption at rest
ENCRYPTION_KEY=
